# =============================================================================
# Frontend (Vite) — obligatorios para que la app funcione
# =============================================================================

# URL del proyecto Supabase (Project Settings > API > Project URL)
VITE_SUPABASE_URL=https://<your-project>.supabase.co

# Supabase Anon Key (Project Settings > API > anon public key)
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Stripe Publishable Key (solo para compra de entradas)
# Se obtiene de: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# Backend (Node.js scripts) — solo para tareas de administración/seed
# =============================================================================

# Service Role Key — para scripts de seed/admin (bypass RLS)
# Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Database — para scripts que conectan directo a PostgreSQL (fix-db.mjs)
# Supabase Dashboard > Project Settings > Database > Database password
DATABASE_PASSWORD=<your-db-password>
DATABASE_HOST=db.<your-project-ref>.supabase.co

# =============================================================================
# Edge Functions (Supabase) — se configuran como secrets en Supabase, no en .env
# =============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# APP_URL=https://redes-sociales-eventos.vercel.app
#
# Para configurarlos en Supabase:
#   npx supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   npx supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   npx supabase secrets set APP_URL=https://tudominio.com
